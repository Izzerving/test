{
  "name": "anonkeymail",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:seed": "node prisma/seed.js",
    "check:compat": "bash scripts/compat_check.sh",
    "quality:gate": "bash scripts/quality_gate.sh",
    "realtime:dev": "ts-node worker/realtime-server.js",
    "payments:retry:dev": "ts-node worker/payment-retry.js",
    "check:domain-policy": "bash scripts/domain_policy_check.sh",
    "smoke:matrix": "bash scripts/e2e_smoke_matrix.sh",
    "staging:matrix": "bash scripts/staging_matrix.sh",
    "security:anonymity": "bash scripts/security_anonymity_check.sh",
    "security:surface": "bash scripts/security_attack_surface_check.sh",
    "security:crash": "bash scripts/crash_resilience_check.sh",
    "e2e:webhooks": "bash scripts/e2e_webhook_contracts.sh",
    "staging:load": "bash scripts/staging_load_slo.sh",
    "ci:gate": "npm run typecheck && npm run lint && npm run build && npm run quality:gate && npm run security:anonymity && npm run security:surface && npm run security:crash",
    "e2e:critical": "npm run smoke:matrix && npm run e2e:webhooks",
    "release:go-no-go": "npm run ci:gate && npm run e2e:critical && npm run staging:load",
    "cleanup:dev": "ts-node worker/cleanup.js",
    "deploy:prod": "prisma migrate deploy && next build && docker compose --profile production up -d --build"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "clsx": "^2.1.1",
    "ioredis": "^5.4.1",
    "lucide-react": "^0.469.0",
    "mailparser": "^3.7.2",
    "next": "^15.1.0",
    "next-themes": "^0.4.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "recharts": "^2.13.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.0.4",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
