generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Tier {
  FREE_GUEST
  FREE_KEY
  PREMIUM
  UNLIMITED
}

enum DomainTier {
  FREE
  PREMIUM
  UNLIMITED
}

enum DomainStatus {
  active
  exhausted
  archived
}

enum PaymentMethod {
  TELEGRAM_STARS
  CRYPTOBOT
  MONERO
  MANUAL
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  CANCELED
  EXPIRED
}

enum PaymentPlan {
  PREMIUM_MONTHLY
  UNLIMITED_LIFETIME
}

enum DeletionInterval {
  D1
  D5
  D10
  D30
  D90
  D180
  Y1
}

model User {
  id               String           @id @default(cuid())
  publicId         String           @unique
  tier             Tier             @default(FREE_KEY)
  keyHash          String           @unique
  keyLookupHash    String           @unique
  keyShownAt       DateTime
  deletionInterval DeletionInterval
  deleteAt         DateTime
  deletedAt        DateTime?        @db.Timestamptz()
  referralCode     String?          @unique
  referredById     String?
  referralBalance  Decimal          @default(0) @db.Decimal(12, 2)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  referredBy       User?            @relation("Referrer", fields: [referredById], references: [id])
  referrals        User[]           @relation("Referrer")
  mailboxes        Mailbox[]
  sessions         Session[]
  payments         Payment[]
  domainAccess     UserDomainAccess[]
  loginLogs        LoginLog[]
  referralBonusesEarned ReferralBonus[] @relation("ReferralBonusReferrer")
  referralBonusesReceived ReferralBonus[] @relation("ReferralBonusReferred")
  withdrawals      Withdrawal[]

  @@index([referredById])
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  createdAt  DateTime @default(now())
  endedAt    DateTime?

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Domain {
  id                String       @id @default(cuid())
  name              String       @unique
  tier              DomainTier
  maxMailboxes      Int          @default(500)
  currentMailboxes  Int          @default(0)
  status            DomainStatus @default(active)
  dnsNs             String?
  transferAfterDays Int?
  transferToTier    DomainTier?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  mailboxes         Mailbox[]
  userAccess        UserDomainAccess[]

  @@index([tier, status])
}

model Mailbox {
  id         String    @id @default(cuid())
  userId     String?
  domainId   String
  localPart  String
  address    String    @unique
  expiresAt  DateTime
  isActive   Boolean   @default(true)
  isGuest    Boolean   @default(false)
  deletedAt  DateTime? @db.Timestamptz()
  createdAt  DateTime  @default(now())

  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  domain     Domain    @relation(fields: [domainId], references: [id], onDelete: Restrict)
  emails     Email[]

  @@index([userId, isActive])
  @@index([domainId, isActive])
}

model Email {
  id          String   @id @default(cuid())
  mailboxId   String
  fromAddress String
  subject     String
  textBody    String?
  htmlBody    String?
  receivedAt  DateTime @default(now())
  deleteAt    DateTime

  mailbox     Mailbox  @relation(fields: [mailboxId], references: [id], onDelete: Cascade)

  @@index([mailboxId, receivedAt])
  @@index([deleteAt])
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  targetTier      Tier
  plan            PaymentPlan
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  amountUsd       Decimal       @db.Decimal(12, 2)
  currency        String
  externalId      String?
  idempotencyKey  String?       @unique
  memo            String?
  confirmations   Int           @default(0)
  retryCount      Int           @default(0)
  nextRetryAt     DateTime?
  processingLock  String?
  lockExpiresAt   DateTime?
  createdAt       DateTime      @default(now())
  confirmedAt     DateTime?

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  referralBonus   ReferralBonus?

  @@index([userId, createdAt])
  @@index([status, nextRetryAt])
  @@index([lockExpiresAt])
  @@index([targetTier, plan])
}

model ReferralBonus {
  id            String   @id @default(cuid())
  referrerId    String
  referredId    String
  type          String
  amountUsd     Decimal  @db.Decimal(12, 2)
  fromPaymentId String?   @unique
  createdAt     DateTime @default(now())

  referrer      User     @relation("ReferralBonusReferrer", fields: [referrerId], references: [id])
  referred      User     @relation("ReferralBonusReferred", fields: [referredId], references: [id])
  payment       Payment? @relation(fields: [fromPaymentId], references: [id])

  @@index([referrerId, createdAt])
  @@index([referredId, createdAt])
}

model Withdrawal {
  id            String   @id @default(cuid())
  userId        String
  amountUsd     Decimal  @db.Decimal(12, 2)
  moneroAddress String
  memo          String?
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
  processedAt   DateTime?

  user          User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model UserDomainAccess {
  id        String   @id @default(uuid())
  userId    String
  domainId  String
  isCustom  Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain    Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@unique([userId, domainId])
  @@index([userId])
  @@index([domainId])
}

model LoginLog {
  id        String   @id @default(cuid())
  userId    String
  ip        String
  userAgent String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model GlobalSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}
